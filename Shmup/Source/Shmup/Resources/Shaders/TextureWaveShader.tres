code = "shader_type canvas_item;
render_mode blend_mix;

uniform float xCut : hint_range(0, 1);
uniform float Intensity : hint_range(0, 0.5);
uniform float xSpeed : hint_range(-5, 5) = 0;
uniform float xOffSet : hint_range(0, 1) = 0;
uniform float yCut : hint_range(0, 1);
uniform float ySpeed : hint_range(-5, 5) = 0;
uniform float yOffSet : hint_range(0, 1) = 0;



void fragment() {
// Input:64
	vec2 n_out64p0 = UV;


// Input:28
	vec2 n_out28p0 = UV;
	float n_out28p1 = n_out28p0.r;
	float n_out28p2 = n_out28p0.g;


// FloatParameter:2
	float n_out2p0 = xCut;


// FloatOp:29
	float n_out29p0 = mod(n_out28p1, n_out2p0);


// FloatOp:30
	float n_out30p0 = n_out29p0 / n_out2p0;


// FloatConstant:8
	float n_out8p0 = 3.141590;


// FloatOp:7
	float n_in7p1 = 2.00000;
	float n_out7p0 = n_out8p0 * n_in7p1;


// FloatOp:34
	float n_out34p0 = n_out30p0 * n_out7p0;


// FloatFunc:25
	float n_out25p0 = sin(n_out34p0);


// FloatParameter:51
	float n_out51p0 = Intensity;


// FloatOp:50
	float n_out50p0 = n_out25p0 * n_out51p0;


// Input:40
	float n_out40p0 = TIME;


// FloatParameter:52
	float n_out52p0 = xSpeed;


// FloatParameter:54
	float n_out54p0 = xOffSet;


// FloatOp:60
	float n_out60p0 = n_out54p0 * n_out7p0;


// MultiplyAdd:56
	float n_out56p0 = fma(n_out40p0, n_out52p0, n_out60p0);


// FloatFunc:58
	float n_out58p0 = sin(n_out56p0);


// FloatOp:49
	float n_out49p0 = n_out50p0 * n_out58p0;


// FloatParameter:66
	float n_out66p0 = yCut;


// FloatOp:27
	float n_out27p0 = mod(n_out28p2, n_out66p0);


// FloatOp:31
	float n_out31p0 = n_out27p0 / n_out66p0;


// FloatOp:33
	float n_out33p0 = n_out31p0 * n_out7p0;


// FloatFunc:32
	float n_out32p0 = sin(n_out33p0);


// FloatOp:47
	float n_out47p0 = n_out32p0 * n_out51p0;


// FloatParameter:53
	float n_out53p0 = ySpeed;


// FloatParameter:55
	float n_out55p0 = yOffSet;


// FloatOp:59
	float n_out59p0 = n_out7p0 * n_out55p0;


// MultiplyAdd:57
	float n_out57p0 = fma(n_out40p0, n_out53p0, n_out59p0);


// FloatFunc:41
	float n_out41p0 = sin(n_out57p0);


// FloatOp:48
	float n_out48p0 = n_out47p0 * n_out41p0;


// VectorCompose:79
	vec2 n_out79p0 = vec2(n_out49p0, n_out48p0);


// VectorOp:65
	vec2 n_in65p1 = vec2(1.00000, 1.00000);
	vec2 n_out65p0 = n_out79p0 / n_in65p1;


// VectorOp:37
	vec2 n_out37p0 = n_out64p0 + n_out65p0;


// Output:0
	COLOR.rgb = vec3(n_out37p0, 0.0);


}
