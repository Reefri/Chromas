code = "shader_type canvas_item;
render_mode blend_mix;

uniform float ExplosionProgression : hint_range(0, 5);
uniform float Duration;
uniform sampler2D screen_tex_frg_21 : hint_screen_texture;



void fragment() {
// Input:2
	vec2 n_out2p0 = UV;


// VectorCompose:4
	float n_in4p0 = 0.50000;
	float n_in4p1 = 0.50000;
	vec2 n_out4p0 = vec2(n_in4p0, n_in4p1);


// Distance:3
	float n_out3p0 = distance(n_out2p0, n_out4p0);


// FloatConstant:39
	float n_out39p0 = 0.500000;


// FloatParameter:30
	float n_out30p0 = ExplosionProgression;


// FloatParameter:33
	float n_out33p0 = Duration;


// FloatOp:29
	float n_out29p0 = n_out30p0 / n_out33p0;


// FloatConstant:41
	float n_out41p0 = 1.570800;


// FloatOp:40
	float n_out40p0 = n_out29p0 * n_out41p0;


// FloatFunc:42
	float n_out42p0 = sin(n_out40p0);


// FloatOp:36
	float n_in36p0 = 1.00000;
	float n_out36p0 = n_in36p0 - n_out42p0;


// FloatOp:38
	float n_in38p1 = 0.25000;
	float n_out38p0 = n_out36p0 * n_in38p1;


// FloatOp:37
	float n_out37p0 = n_out39p0 - n_out38p0;


	vec4 n_out21p0;
// Texture2D:21
	n_out21p0 = texture(screen_tex_frg_21, SCREEN_UV);
	float n_out21p1 = n_out21p0.r;
	float n_out21p2 = n_out21p0.g;
	float n_out21p3 = n_out21p0.b;
	float n_out21p4 = n_out21p0.a;


// FloatOp:16
	float n_in16p0 = 1.00000;
	float n_out16p0 = n_in16p0 - n_out21p1;


// FloatOp:19
	float n_in19p0 = 1.00000;
	float n_out19p0 = n_in19p0 - n_out21p2;


// FloatOp:20
	float n_in20p0 = 1.00000;
	float n_out20p0 = n_in20p0 - n_out21p3;


// VectorCompose:17
	vec4 n_out17p0 = vec4(n_out16p0, n_out19p0, n_out20p0, n_out21p4);


	vec3 n_out23p0;
// If:23
	if(abs(n_out3p0 - n_out37p0) < n_out38p0)
	{
		n_out23p0 = vec3(n_out17p0.xyz);
	}
	else if(n_out3p0 < n_out37p0)
	{
		n_out23p0 = vec3(n_out21p0.xyz);
	}
	else
	{
		n_out23p0 = vec3(n_out21p0.xyz);
	}


// Output:0
	COLOR.rgb = n_out23p0;


}
"
