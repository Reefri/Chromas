code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec2 red;
uniform sampler2D screen_tex_frg_3 : hint_screen_texture;
uniform vec2 green;
uniform sampler2D screen_tex_frg_5 : hint_screen_texture;
uniform vec2 blue;
uniform sampler2D screen_tex_frg_6 : hint_screen_texture;



void fragment() {
// Input:13
	vec2 n_out13p0 = SCREEN_PIXEL_SIZE;
	float n_out13p1 = n_out13p0.r;
	float n_out13p2 = n_out13p0.g;


// FloatOp:14
	float n_out14p0 = n_out13p1 / n_out13p2;


// VectorCompose:15
	float n_in15p0 = 1.00000;
	vec2 n_out15p0 = vec2(n_in15p0, n_out14p0);


// Vector2Parameter:10
	vec2 n_out10p0 = red;


// VectorOp:17
	vec2 n_out17p0 = n_out15p0 * n_out10p0;


// Input:2
	vec2 n_out2p0 = SCREEN_UV;


// VectorOp:7
	vec2 n_out7p0 = n_out17p0 + n_out2p0;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(screen_tex_frg_3, n_out7p0);
	float n_out3p1 = n_out3p0.r;


// Vector2Parameter:11
	vec2 n_out11p0 = green;


// VectorOp:16
	vec2 n_out16p0 = n_out15p0 * n_out11p0;


// VectorOp:8
	vec2 n_out8p0 = n_out16p0 + n_out2p0;


	vec4 n_out5p0;
// Texture2D:5
	n_out5p0 = texture(screen_tex_frg_5, n_out8p0);
	float n_out5p2 = n_out5p0.g;


// Vector2Parameter:12
	vec2 n_out12p0 = blue;


// VectorOp:18
	vec2 n_out18p0 = n_out15p0 * n_out12p0;


// VectorOp:9
	vec2 n_out9p0 = n_out18p0 + n_out2p0;


	vec4 n_out6p0;
// Texture2D:6
	n_out6p0 = texture(screen_tex_frg_6, n_out9p0);
	float n_out6p3 = n_out6p0.b;


// VectorCompose:4
	vec3 n_out4p0 = vec3(n_out3p1, n_out5p2, n_out6p3);


// Output:0
	COLOR.rgb = n_out4p0;


}
"
