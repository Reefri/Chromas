code = "shader_type canvas_item;
render_mode blend_mix;

uniform float speed;
uniform vec2 centerPosition = vec2(0.500000, 0.500000);
uniform float xCut : hint_range(0, 1);
uniform float Intensity : hint_range(0, 0.5);
uniform float xSpeed : hint_range(-5, 5) = 0;
uniform float xOffSet : hint_range(0, 1) = 0;
uniform float yCut : hint_range(0, 1);
uniform float ySpeed : hint_range(-5, 5) = 0;
uniform float yOffSet : hint_range(0, 1) = 0;
uniform float circleSize : hint_range(0, 10) = 0.5;
uniform int colorNumber;
uniform float saturation : hint_range(0, 1);
uniform float value : hint_range(0, 1);
uniform float close : hint_range(0, 1);



void fragment() {
// Input:16
	float n_out16p0 = TIME;


// FloatParameter:15
	float n_out15p0 = speed;


// FloatOp:18
	float n_out18p0 = n_out16p0 / n_out15p0;


// Vector2Parameter:19
	vec2 n_out19p0 = centerPosition;


// Input:77
	vec2 n_out77p0 = UV;


// Input:46
	vec2 n_out46p0 = UV;
	float n_out46p1 = n_out46p0.r;
	float n_out46p2 = n_out46p0.g;


// FloatParameter:40
	float n_out40p0 = xCut;


// FloatOp:47
	float n_out47p0 = mod(n_out46p1, n_out40p0);


// FloatOp:48
	float n_out48p0 = n_out47p0 / n_out40p0;


// FloatConstant:42
	float n_out42p0 = 3.141590;


// FloatOp:41
	float n_in41p1 = 2.00000;
	float n_out41p0 = n_out42p0 * n_in41p1;


// FloatOp:52
	float n_out52p0 = n_out48p0 * n_out41p0;


// FloatFunc:44
	float n_out44p0 = sin(n_out52p0);


// FloatParameter:59
	float n_out59p0 = Intensity;


// FloatOp:58
	float n_out58p0 = n_out44p0 * n_out59p0;


// Input:53
	float n_out53p0 = TIME;


// FloatParameter:60
	float n_out60p0 = xSpeed;


// FloatParameter:62
	float n_out62p0 = xOffSet;


// FloatOp:68
	float n_out68p0 = n_out62p0 * n_out41p0;


// MultiplyAdd:64
	float n_out64p0 = fma(n_out53p0, n_out60p0, n_out68p0);


// FloatFunc:66
	float n_out66p0 = sin(n_out64p0);


// FloatOp:57
	float n_out57p0 = n_out58p0 * n_out66p0;


// FloatParameter:71
	float n_out71p0 = yCut;


// FloatOp:45
	float n_out45p0 = mod(n_out46p2, n_out71p0);


// FloatOp:49
	float n_out49p0 = n_out45p0 / n_out71p0;


// FloatOp:51
	float n_out51p0 = n_out49p0 * n_out41p0;


// FloatFunc:50
	float n_out50p0 = sin(n_out51p0);


// FloatOp:55
	float n_out55p0 = n_out50p0 * n_out59p0;


// FloatParameter:61
	float n_out61p0 = ySpeed;


// FloatParameter:63
	float n_out63p0 = yOffSet;


// FloatOp:67
	float n_out67p0 = n_out41p0 * n_out63p0;


// MultiplyAdd:65
	float n_out65p0 = fma(n_out53p0, n_out61p0, n_out67p0);


// FloatFunc:54
	float n_out54p0 = sin(n_out65p0);


// FloatOp:56
	float n_out56p0 = n_out55p0 * n_out54p0;


// VectorCompose:72
	vec2 n_out72p0 = vec2(n_out57p0, n_out56p0);


// VectorOp:70
	vec2 n_in70p1 = vec2(1.00000, 1.00000);
	vec2 n_out70p0 = n_out72p0 / n_in70p1;


// VectorOp:76
	vec2 n_out76p0 = n_out77p0 + n_out70p0;


// Distance:5
	float n_out5p0 = distance(n_out19p0, n_out76p0);


// FloatParameter:25
	float n_out25p0 = circleSize;


// FloatOp:13
	float n_out13p0 = n_out5p0 / n_out25p0;


// FloatOp:17
	float n_out17p0 = n_out18p0 + n_out13p0;


// IntParameter:27
	int n_out27p0 = colorNumber;


// FloatOp:28
	float n_in28p0 = 1.00000;
	float n_out28p0 = n_in28p0 / float(n_out27p0);


// FloatOp:26
	float n_out26p0 = mod(n_out17p0, n_out28p0);


// FloatOp:29
	float n_out29p0 = n_out17p0 - n_out26p0;


// FloatParameter:8
	float n_out8p0 = saturation;


// FloatParameter:9
	float n_out9p0 = value;


// FloatOp:37
	float n_out37p0 = n_out26p0 / n_out28p0;


// FloatOp:38
	float n_out38p0 = n_out9p0 * n_out37p0;


// FloatFunc:39
	float n_out39p0 = 1.0 - n_out38p0;


// VectorCompose:7
	vec3 n_out7p0 = vec3(n_out29p0, n_out8p0, n_out39p0);


	vec3 n_out10p0;
// ColorFunc:10
	{
		vec3 c = n_out7p0;
		vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
		vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
		n_out10p0 = c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
	}


// FloatOp:31
	float n_out31p0 = mod(n_out5p0, n_out28p0);


// FloatOp:32
	float n_out32p0 = n_out5p0 - n_out31p0;


// FloatParameter:30
	float n_out30p0 = close;


// FloatConstant:34
	float n_out34p0 = 1.414210;


// FloatOp:35
	float n_in35p1 = 1.00000;
	float n_out35p0 = n_out34p0 / n_in35p1;


// FloatOp:36
	float n_out36p0 = n_out30p0 / n_out35p0;


// Compare:33
	bool n_out33p0 = n_out32p0 >= n_out36p0;


// Output:0
	COLOR.rgb = n_out10p0;
	COLOR.a = (n_out33p0 ? 1.0 : 0.0);


}
