[sub_resource type="VisualShaderNodeColorParameter" id="VisualShaderNodeColorParameter_13rkw"]
parameter_name = "Color"

[resource]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform bool isActive = true;
uniform vec4 Color : source_color;



void fragment() {
// BooleanParameter:4
	bool n_out4p0 = isActive;


// ColorParameter:6
	vec4 n_out6p0 = Color;


// Input:2
	vec4 n_out2p0 = COLOR;


	vec3 n_out5p0;
// If:5
	float n_in5p1 = 1.00000;
	float n_in5p2 = 0.00001;
	if(abs((n_out4p0 ? 1.0 : 0.0) - n_in5p1) < n_in5p2)
	{
		n_out5p0 = vec3(n_out6p0.xyz);
	}
	else if((n_out4p0 ? 1.0 : 0.0) < n_in5p1)
	{
		n_out5p0 = vec3(n_out2p0.xyz);
	}
	else
	{
		n_out5p0 = vec3(n_out2p0.xyz);
	}


// Output:0
	COLOR.rgb = n_out5p0;


}
"
