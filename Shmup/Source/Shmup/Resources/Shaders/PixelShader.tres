[resource]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform float pixelSize : hint_range(0.0010000000475, 10);
uniform sampler2D screen_tex_frg_2 : hint_screen_texture;



void fragment() {
// Input:3
	vec2 n_out3p0 = SCREEN_UV;


// FloatParameter:17
	float n_out17p0 = pixelSize;


// Input:7
	vec2 n_out7p0 = SCREEN_PIXEL_SIZE;


// VectorOp:16
	vec2 n_out16p0 = vec2(n_out17p0) * n_out7p0;


// VectorOp:12
	vec2 n_out12p0 = mod(n_out3p0, n_out16p0);


// VectorOp:13
	vec2 n_out13p0 = n_out3p0 - n_out12p0;


	vec4 n_out2p0;
// Texture2D:2
	n_out2p0 = texture(screen_tex_frg_2, n_out13p0);


// Output:0
	COLOR.rgb = vec3(n_out2p0.xyz);


}
"
