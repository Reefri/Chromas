code = "shader_type canvas_item;
render_mode blend_mix;

uniform bool ToggleUpDown;
uniform float margin : hint_range(0, 1);



void fragment() {
// BooleanParameter:4
	bool n_out4p0 = ToggleUpDown;


// FloatParameter:7
	float n_out7p0 = margin;


// Input:2
	vec2 n_out2p0 = UV;
	float n_out2p2 = n_out2p0.g;


// FloatOp:9
	float n_out9p0 = n_out2p2 / n_out7p0;


// IntConstant:10
	int n_out10p0 = 1;


	vec3 n_out8p0;
// If:8
	float n_in8p2 = 0.00001;
	vec3 n_in8p3 = vec3(0.00000, 0.00000, 0.00000);
	if(abs(n_out7p0 - n_out2p2) < n_in8p2)
	{
		n_out8p0 = n_in8p3;
	}
	else if(n_out7p0 < n_out2p2)
	{
		n_out8p0 = vec3(float(n_out10p0));
	}
	else
	{
		n_out8p0 = vec3(n_out9p0);
	}


// FloatOp:3
	float n_in3p0 = 1.00000;
	float n_out3p0 = n_in3p0 - n_out2p2;


// FloatOp:11
	float n_out11p0 = n_out3p0 / n_out7p0;


	vec3 n_out6p0;
// If:6
	float n_in6p1 = 1.00000;
	float n_in6p2 = 0.00001;
	if(abs((n_out4p0 ? 1.0 : 0.0) - n_in6p1) < n_in6p2)
	{
		n_out6p0 = n_out8p0;
	}
	else if((n_out4p0 ? 1.0 : 0.0) < n_in6p1)
	{
		n_out6p0 = vec3(n_out11p0);
	}
	else
	{
		n_out6p0 = vec3(n_out11p0);
	}


// Output:0
	COLOR.a = n_out6p0.x;


}
