code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec4 color : source_color = vec4(0.000000, 0.000000, 0.000000, 1.000000);
uniform float progression : hint_range(0, 1);



void fragment() {
// ColorParameter:10
	vec4 n_out10p0 = color;


// Input:2
	vec2 n_out2p0 = UV;


// Vector2Constant:5
	vec2 n_out5p0 = vec2(0.500000, 0.500000);


// Distance:3
	float n_out3p0 = distance(n_out2p0, n_out5p0);


// FloatParameter:8
	float n_out8p0 = progression;


// FloatConstant:7
	float n_out7p0 = 0.500000;


// FloatOp:9
	float n_out9p0 = n_out8p0 * n_out7p0;


// Compare:6
	bool n_out6p0 = n_out3p0 <= n_out9p0;


// Output:0
	COLOR.rgb = vec3(n_out10p0.xyz);
	COLOR.a = (n_out6p0 ? 1.0 : 0.0);


}
"
