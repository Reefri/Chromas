code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D tex_frg_2 : source_color;
uniform float accuracy : hint_range(0, 20);
uniform vec2 position;
uniform sampler2D screen_tex_frg_5 : hint_screen_texture;



void fragment() {
// ColorConstant:9
	vec4 n_out9p0 = vec4(1.000000, 1.000000, 1.000000, 1.000000);


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, UV);


// FloatParameter:11
	float n_out11p0 = accuracy;


// Input:12
	vec2 n_out12p0 = SCREEN_UV;


// VectorOp:13
	vec2 n_out13p0 = n_out12p0 - vec2(n_out2p0.xy);


// Vector2Parameter:14
	vec2 n_out14p0 = position;


// VectorOp:16
	vec2 n_out16p0 = n_out13p0 + n_out14p0;


	vec3 n_out10p0;
// If:10
	if(abs(n_out9p0.x - n_out2p0.x) < n_out11p0)
	{
		n_out10p0 = vec3(n_out12p0, 0.0);
	}
	else if(n_out9p0.x < n_out2p0.x)
	{
		n_out10p0 = vec3(n_out16p0, 0.0);
	}
	else
	{
		n_out10p0 = vec3(n_out16p0, 0.0);
	}


	vec4 n_out5p0;
// Texture2D:5
	n_out5p0 = texture(screen_tex_frg_5, vec2(n_out10p0.xy));


// Output:0
	COLOR.rgb = vec3(n_out5p0.xyz);


}
"
