[resource]
code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D screen_tex_frg_4 : hint_screen_texture;
uniform vec4 color : source_color = vec4(1.000000, 1.000000, 1.000000, 1.000000);
uniform float tolerance : hint_range(0, 1.00100004673004);



void fragment() {
// Input:3
	vec2 n_out3p0 = SCREEN_UV;


	vec4 n_out4p0;
// Texture2D:4
	n_out4p0 = texture(screen_tex_frg_4, n_out3p0);
	float n_out4p1 = n_out4p0.r;
	float n_out4p2 = n_out4p0.g;
	float n_out4p3 = n_out4p0.b;


// ColorParameter:2
	vec4 n_out2p0 = color;
	float n_out2p1 = n_out2p0.r;
	float n_out2p2 = n_out2p0.g;
	float n_out2p3 = n_out2p0.b;


// FloatParameter:14
	float n_out14p0 = tolerance;


// Compare:11
	bool n_out11p0 = (abs(n_out4p1 - n_out2p1) < n_out14p0);

// Compare:12
	bool n_out12p0 = (abs(n_out4p2 - n_out2p2) < n_out14p0);

// FloatOp:16
	float n_out16p0 = (n_out11p0 ? 1.0 : 0.0) * (n_out12p0 ? 1.0 : 0.0);


// Compare:13
	bool n_out13p0 = (abs(n_out4p3 - n_out2p3) < n_out14p0);

// FloatOp:15
	float n_out15p0 = n_out16p0 * (n_out13p0 ? 1.0 : 0.0);


// Output:0
	COLOR.a = n_out15p0;


}
